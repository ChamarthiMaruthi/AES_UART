
module inverseShiftRows (
    input  wire [127:0] in,
    output wire [127:0] out
);
    wire [7:0] b [0:15];
    genvar i;
    generate
        for (i=0;i<16;i=i+1) assign b[i] = in[127 - 8*i -: 8];
    endgenerate

    // Row0: no shift
    assign out[127 -: 8] = b[0];
    assign out[119 -: 8] = b[1];
    assign out[111 -: 8] = b[2];
    assign out[103 -: 8] = b[3];

    // Row1: right shift by 1 (equivalently left by 3)
    assign out[95  -: 8] = b[7];
    assign out[87  -: 8] = b[4];
    assign out[79  -: 8] = b[5];
    assign out[71  -: 8] = b[6];

    // Row2: right shift by 2 (left by 2)
    assign out[63  -: 8] = b[10];
    assign out[55  -: 8] = b[11];
    assign out[47  -: 8] = b[8];
    assign out[39  -: 8] = b[9];

    // Row3: right shift by 3 (left by 1)
    assign out[31  -: 8] = b[14];
    assign out[23  -: 8] = b[15];
    assign out[15  -: 8] = b[12];
    assign out[7   -: 8] = b[13];
endmodule
